// MCP server 配置骨架（共享 `.mcp.json`）
//
// teammate 形态要点：
//   - GitHub 双轨：路径A gh-mcp OAuth（推荐）+ 路径B Copilot MCP PAT（备选），互斥二选一
//   - Jira：Atlassian Plugin（/plugin install atlassian@claude-plugins-official → /mcp OAuth 授权）
//   - 独占靠各 agent 的 tools 白名单
//   - 不走 agent frontmatter 内联——teammate 形态下 frontmatter 的 mcpServers 被忽略
{
  "mcpServers": {
    // ============================================================
    // GitHub 双轨认证：互斥二选一（同一 server 名 "github"）
    // ============================================================

    // --- 路径A：gh-mcp OAuth（推荐，有浏览器）---
    // 使用 gh CLI 扩展 shuymn/gh-mcp，通过 gh auth login 浏览器 OAuth 认证
    // 安装 gh CLI：winget install --id GitHub.cli (Win) / brew install gh (macOS)
    // 登录：gh auth login → HTTPS → Login with a web browser（支持公司 SSO）
    // 安装扩展：gh extension install shuymn/gh-mcp
    // 无需手动创建 PAT——gh CLI 的 OAuth token 由 keyring 管理
    "github": {
      "command": "gh",
      "args": ["mcp"],
      "env": {
        "GITHUB_READ_ONLY": "1"
      }
    }

    // --- 路径B：Copilot MCP + PAT（备选，headless/无浏览器）---
    // 使用 GitHub Copilot 托管 MCP，通过 GITHUB_TOKEN PAT 环境变量认证
    // PAT 要求：classic token，scope 勾选 repo（+ read:org 如需组织访问）
    // Org repo：在 GitHub token 页面点击 Configure SSO 授权对应 org
    // 切换方式：注释上方路径A条目，取消下方路径B条目的注释
    //
    // "github": {
    //   "type": "http",
    //   "url": "https://api.githubcopilot.com/mcp",
    //   "headers": {
    //     "Authorization": "Bearer ${GITHUB_TOKEN}",
    //     "X-MCP-Readonly": "true"
    //   }
    // }

    // --- Atlassian (Jira) ---
    // 官方 Atlassian Plugin：/plugin install atlassian@claude-plugins-official → /mcp Authenticate
    // server 名: atlassian  工具前缀: mcp__atlassian__*
    // 无需在此添加条目——Plugin 自行注册
  }
}

// === 路径B 环境变量设置（防终端历史泄漏） ===
//   Windows PowerShell：
//     $token = Read-Host -Prompt "请粘贴 GitHub PAT" -MaskInput
//     [Environment]::SetEnvironmentVariable("GITHUB_TOKEN", $token, "User")
//     重启终端使变量生效
//   macOS/Linux：
//     read -s -p "请粘贴 GitHub PAT: " token && export GITHUB_TOKEN=$token
